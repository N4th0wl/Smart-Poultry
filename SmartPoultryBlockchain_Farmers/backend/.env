# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smartpoultry_peternakan

# Auth / Security
JWT_SECRET=super_secret_jwt_key
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# Uploads
UPLOAD_DIR=uploads

# Cross-Chain: Kurir Database (read-only for blockchain monitoring)
KURIR_DB_HOST=localhost
KURIR_DB_PORT=3306
KURIR_DB_USER=root
KURIR_DB_PASSWORD=
KURIR_DB_NAME=smartpoultry_kurir

# Cross-Chain: Processor Database (read-only for blockchain monitoring)
PROCESSOR_DB_HOST=localhost
PROCESSOR_DB_PORT=3306
PROCESSOR_DB_USER=root
PROCESSOR_DB_PASSWORD=
PROCESSOR_DB_NAME=smartpoultry_processor

# Cross-Chain: Retailer Database (read-only for blockchain monitoring)
RETAILER_DB_HOST=localhost
RETAILER_DB_PORT=3306
RETAILER_DB_USER=root
RETAILER_DB_PASSWORD=
RETAILER_DB_NAME=smartpoultry_retailer

# Single Processor Configuration (satu-satunya tujuan pengiriman)
PROCESSOR_NAME=PT Ayam Potong SmartPoultry
PROCESSOR_ADDRESS=Jl. Industri No. 1, Jakarta

# (Opsional) Email / Cloud services, isi jika diperlukan
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=