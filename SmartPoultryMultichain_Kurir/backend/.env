# Server
PORT=5002
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5174

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smartpoultry_kurir

# Auth / Security
JWT_SECRET=kurir_super_secret_jwt_key
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

# Cross-Chain: Peternakan Database (read-only for blockchain sync)
PETERNAKAN_DB_HOST=localhost
PETERNAKAN_DB_PORT=3306
PETERNAKAN_DB_USER=root
PETERNAKAN_DB_PASSWORD=
PETERNAKAN_DB_NAME=smartpoultry_peternakan

# Cross-Chain: Peternakan API (fallback)
PETERNAKAN_API_URL=http://localhost:5000/api

# Cross-Chain: Processor Database (read-only for blockchain monitoring)
PROCESSOR_DB_HOST=localhost
PROCESSOR_DB_PORT=3306
PROCESSOR_DB_USER=root
PROCESSOR_DB_PASSWORD=
PROCESSOR_DB_NAME=smartpoultry_processor

# Cross-Chain: Retailer Database (read-only for blockchain monitoring)
RETAILER_DB_HOST=localhost
RETAILER_DB_PORT=3306
RETAILER_DB_USER=root
RETAILER_DB_PASSWORD=
RETAILER_DB_NAME=smartpoultry_retailer
